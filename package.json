{
  "name": "@spooky/blog-sveltekit",
  "version": "3.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:update-snapshots:linux": "docker run --rm --ipc=host --network host -v $(pwd):/work -w /work -e CI=1 mcr.microsoft.com/playwright:v1.59.1-jammy sh -c 'npm install -g pnpm@10.28.2 && pnpm install --frozen-lockfile && pnpm exec playwright test --update-snapshots'"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "mdsvex": "^0.12.7",
    "shiki": "^4.0.2",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "date-fns": "^4.1.0",
    "feed": "^5.2.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "luxon": "^3.5.0",
    "marked": "^18.0.2",
    "posthog-js": "^1.369.2",
    "svelte": "^5.55.4",
    "vite": "^8.0.9"
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "^7.5.5"
    }
  }
}
